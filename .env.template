# Grid Trading Bot — Environment Variables
# Copy to .env on the Oracle VM and fill in real values.
# NEVER commit .env — it contains live API keys with trading permissions.

# ── crypto.com Exchange API (Trade permission only — no withdrawal) ────────────
CDX_API_KEY=your_cdx_api_key_here
CDX_API_SECRET=your_cdx_api_secret_here

# ── Google Gemini AI (weekly optimisation) ────────────────────────────────────
# Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram (kill switch alerts + daily reports) ────────────────────────────
# Step 1: message @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
# Step 2: message @userinfobot on Telegram → copy your chat ID
TELEGRAM_CHAT_ID=987654321

# ── Capital settings (override config/grid_params.json defaults) ──────────────
TOTAL_CAPITAL_GBP=150
GBP_USD_RATE=1.27
KILL_SWITCH_PCT=0.10
